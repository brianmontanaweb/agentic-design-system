{
  "name": "@agentic-ds/tokens",
  "version": "0.1.0",
  "description": "Design tokens for the Agentic Design System — framework-agnostic JS constants and CSS custom properties",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianmontanaweb/agentic-design-system.git",
    "directory": "packages/tokens"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "agentic",
    "mcp",
    "css-variables"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "tokens:generate": "tsx scripts/generate.ts",
    "build": "npm run tokens:generate && tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsx": "^4.16.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public"
  }
}
