{
  "name": "@agentic-ds/core",
  "version": "0.1.0",
  "description": "Core components and theme for the Agentic Design System — AgenticProvider, Button, CodeBlock",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/brianmontanaweb/agentic-design-system.git",
    "directory": "packages/core"
  },
  "keywords": [
    "design-system",
    "agentic",
    "mcp",
    "react",
    "chakra-ui",
    "components"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "next-themes": "^0.4.6"
  },
  "peerDependencies": {
    "@agentic-ds/tokens": "^0.1.0",
    "@chakra-ui/react": "^3.34.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@agentic-ds/tokens": "*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
