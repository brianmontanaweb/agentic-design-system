{
  "name": "@agentic-ds/mcp-builder",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing Agentic Design System tokens and component metadata to AI tools",
  "type": "module",
  "bin": {
    "agentic-ds-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./iife": "./dist/iife/agentic-ds.global.js",
    "./iife/min": "./dist/iife/agentic-ds.min.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentic-ds/agents": "*",
    "@agentic-ds/core": "*",
    "@agentic-ds/tokens": "*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^6.0.2",
    "vitest": "^2.0.0"
  }
}
