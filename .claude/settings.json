{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:storybook.js.org)",
      "WebFetch(domain:github.com)",
      "Bash(npm run:*)",
      "Bash(npm view:*)",
      "Bash(grep -v \"^npm error$\")",
      "Bash(xargs rm:*)",
      "Bash(node -e \"const p = require\\(''''./node_modules/@storybook/test-runner/package.json''''\\); console.log\\(JSON.stringify\\(p.dependencies || {}, null, 2\\)\\)\")",
      "Bash(node -e \"const d=JSON.parse\\(require\\(''''fs''''\\).readFileSync\\(''''/dev/stdin'''',''''utf8''''\\)\\); console.log\\(Object.keys\\(d.dependencies||{}\\).filter\\(k=>k.includes\\(''''playwright''''\\)\\)\\)\")",
      "Bash(gh auth:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git remote:*)",
      "Bash(git push:*)",
      "Bash(find /Users/brianmontana/code/agentic-design-system/packages/mcp-builder/src -type f \\\\\\(-name *.ts -o -name *.tsx \\\\\\))",
      "Bash(xargs -I {} basename {})",
      "Bash(wc -l /Users/brianmontana/code/agentic-design-system/apps/storybook/src/stories/*.tsx)",
      "WebFetch(domain:www.d4b.dev)",
      "WebFetch(domain:developers.openai.com)",
      "WebFetch(domain:blog.modelcontextprotocol.io)",
      "WebFetch(domain:medium.com)",
      "Bash(npx prettier --write:*)",
      "Bash(npx eslint:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "file=$(echo $CLAUDE_TOOL_INPUT | node -e \"process.stdin.resume();let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{try{console.log(JSON.parse(d).file_path||'')}catch(e){}})\"); if [[ \"$file\" == *.ts || \"$file\" == *.tsx || \"$file\" == *.json || \"$file\" == *.md ]]; then npx prettier --write \"$file\" 2>/dev/null; fi"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    }
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
